				{
					"name": "User log in and Get Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Проверяем, что запрос прошел успешно (код ответа 200-299)",
									"if (pm.response.code >= 200 && pm.response.code < 300) {",
									"    // Пробуем получить заголовок Authorization",
									"    const authHeader = pm.response.headers.get('Authorization');",
									"    ",
									"    // Если заголовок найден, сохраняем его в переменную среды",
									"    if (authHeader) {",
									"        pm.environment.set('authToken', authHeader);",
									"        console.log('Токен успешно сохранен:', authHeader);",
									"    } else {",
									"        console.log('Заголовок Authorization не найден в ответе.');",
									"    }",
									"} else {",
									"    console.log('Запрос авторизации не удался. Код ответа:', pm.response.code);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {

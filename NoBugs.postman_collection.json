				{
					"name": "User can create a new account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Проверяем, что запрос прошел успешно",
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    // Парсим тело ответа в формат JSON",
									"    const responseJson = pm.response.json();",
									"    ",
									"    // Проверяем, что поле 'id' существует в ответе",
									"    if (responseJson.id) {",
									"        // Сохраняем значение id в переменную среды",
									"        pm.environment.set(\"accountId\", responseJson.id);",
									"        console.log(\"Успешно сохранен ID аккаунта: \" + responseJson.id);",
									"    } else {",
									"        console.log(\"Поле 'id' не найдено в теле ответа.\");",
									"    }",
									"} else {",
									"    console.log(\"Запрос не выполнен. Код ответа: \" + pm.response.code);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
